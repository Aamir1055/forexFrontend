# Base path for development (served at root)
VITE_BASE_PATH=/

# Leave empty so API requests use relative URLs and go through the Vite proxy (avoids CORS)
# The proxy in vite.config.ts forwards /api/* to the backend server-side
VITE_API_BASE_URL=

# Optional: Override to use local backend for development
# VITE_API_BASE_URL=http://localhost:8080
